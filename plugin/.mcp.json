{
  "mcpServers": {
    "ziiagentmemory": {
      "command": "npx",
      "args": ["-y", "ziiagentmemory"],
      "env": {
        "ZIIAGENTMEMORY_URL": "${ZIIAGENTMEMORY_URL:-http://localhost:3111}",
        "ZIIAGENTMEMORY_SECRET": "${ZIIAGENTMEMORY_SECRET:-}",
        "ZIIAGENTMEMORY_TOOLS": "${ZIIAGENTMEMORY_TOOLS:-all}"
      }
    }
  }
}
